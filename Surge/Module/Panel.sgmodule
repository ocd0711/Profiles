#!name=OCD used Panel
#!desc=timecard, chatgpt_check, captureMode, gpt_ai_panel, credit_card_interest_free_panel

[Script]
timecard = type=generic, timeout=10, script-path=https://raw.githubusercontent.com/smartmimi/conf/master/surge/timecard.js
gpt_ai_panel = type=generic, timeout=20, script-path=https://raw.githubusercontent.com/ocd0711/Profiles/master/Surge/Js/gpt_ai_panel.js, argument=icon=lasso.and.sparkles&iconerr=xmark.seal.fill&icon-color=#336FA9&iconerr-color=#D65C51
captureMode = type=generic, timeout=10, script-path=https://raw.githubusercontent.com/ocd0711/Profiles/master/Surge/Js/captureMode.js

[Panel]
timecard = script-name=timecard, update-interval=43200
gpt_ai_panel = script-name=gpt_ai_panel, update-interval=43200
captureMode = script-name=captureMode, update-interval=43200
